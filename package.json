{
  "name": "dg-chat",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cf:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "android:dev": "npm run dev -w @dg-chat/tauri-android",
    "android:build": "npm run build -w @dg-chat/tauri-android",
    "tauri:android:init": "npm run tauri:android:init -w @dg-chat/tauri-android",
    "tauri:android:dev": "npm run tauri:android:dev -w @dg-chat/tauri-android",
    "tauri:android:build": "npm run tauri:android:build -w @dg-chat/tauri-android"
  },
  "dependencies": {
    "@dg-kit/core": "^1.3.0",
    "@dg-kit/protocol": "^1.3.0",
    "@dg-kit/transport-webbluetooth": "^1.3.0",
    "@dg-kit/waveforms": "^1.3.0",
    "fflate": "^0.8.2",
    "lucide-react": "^1.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wrangler": "^4.98.0"
  }
}
