<?xml version="1.0" encoding="utf-8"?>
<!--
  Template for src-tauri/gen/android/app/src/main/AndroidManifest.xml.

  `cargo tauri android init` regenerates that file from scratch every
  time. After re-init, copy the <uses-permission> / <uses-feature>
  entries below into the generated manifest's <manifest> root.

  Permission notes:
    * BLUETOOTH_SCAN / BLUETOOTH_CONNECT — required on Android 12+ (API 31+).
      `usesPermissionFlags="neverForLocation"` tells the OS we will not use
      BLE scan results to infer physical location, which (a) avoids the
      stricter location-permission prompt and (b) is accurate for DG-Lab
      Coyote: we filter on the device's broadcast name.
    * BLUETOOTH / BLUETOOTH_ADMIN — pre-Android-12 equivalents, capped at
      SDK 30 so they aren't requested on newer devices where the runtime
      ignores them.
    * ACCESS_*_LOCATION — Android 6-11 (API 23-30) required Location to
      run any BLE scan. Capped at SDK 30 since 12+ uses BLUETOOTH_SCAN
      with neverForLocation instead.
    * INTERNET — the room transport is a WebSocket to the Cloudflare Durable
      Object relay (see worker/room-do.ts), not PeerJS/WebRTC — there is no
      P2P signaling step, everything rides this one connection.
    * uses-feature bluetooth_le required="false" — the app should install
      on emulators / devices without BLE so the chat-only / spectator
      mode still works.
    * RECORD_AUDIO / MODIFY_AUDIO_SETTINGS — voice messages (getUserMedia +
      MediaRecorder in src/lib/media.ts). Both are required, not just
      RECORD_AUDIO: wry's WebChromeClient.onPermissionRequest() grants only
      if every requested Android permission is present in the manifest, and
      an undeclared permission comes back `false` from the runtime prompt —
      so omitting MODIFY_AUDIO_SETTINGS makes the whole grant fail with an
      opaque NotAllowedError instead of the mic simply not working.

  Also bump app/build.gradle.kts minSdk to 26 — required by
  @mnlphlp/plugin-blec's Android backend.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Android 12+ (API 31+) BLE -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
                     android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Android 6 - 11 BLE -->
    <uses-permission android:name="android.permission.BLUETOOTH"
                     android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
                     android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
                     android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
                     android:maxSdkVersion="30" />

    <!-- Voice messages -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <uses-feature android:name="android.hardware.bluetooth_le"
                  android:required="false" />
    <uses-feature android:name="android.hardware.microphone"
                  android:required="false" />

    <!--
      <application> entries are managed by Tauri's manifest generator.
      Do not duplicate them here.
    -->

</manifest>
